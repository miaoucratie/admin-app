{
  "expo": {
    "name": "Miaoucratie Admin",
    "slug": "miaoucratieadmin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "miaoucratieadmin",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6EFE9"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.miaoucratieadmin.app"
    },
    "android": {
      "package": "com.miaoucratieadmin.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "output": "single",
      "name": "Miaoucratie — Indisponibilités",
      "shortName": "Indispo",
      "themeColor": "#A8472A",
      "backgroundColor": "#F6EFE9",
      "display": "standalone",
      "lang": "fr"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}